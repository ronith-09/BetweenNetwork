# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=betweennetwork
DB_USER=postgres
DB_PASSWORD=your_password

# Server
PORT=3000
NODE_ENV=development

# Blockchain
FABRIC_NETWORK_NAME=basic
FABRIC_CONNECTION_PROFILE=/absolute/path/to/connection-profile.json
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=participant-chaincode
FABRIC_DISCOVERY_ENABLED=true
FABRIC_DISCOVERY_AS_LOCALHOST=true
FABRIC_PEER_ADDRESS=localhost:7051
FABRIC_CA_URL=http://localhost:7054
FABRIC_ORDERER_ADDRESS=localhost:7050
FABRIC_ORDERER_NAME=orderer.example.com
FABRIC_MSP_ID=BetweenNetworkMSP
FABRIC_ADMIN_USER=admin
FABRIC_ADMIN_PASSWORD=adminpw
TEST_NETWORK_DIR=/absolute/path/to/fabric-samples/test-network
BLOCKCHAIN_ORG_ONBOARDING_SCRIPT=/absolute/path/to/fabric-samples/test-network/dynamic-org/onboard-bank-org.sh

# JWT/Auth
JWT_SECRET=your_jwt_secret
ADMIN_API_KEY=your_admin_api_key

# Logging
LOG_LEVEL=info
